{
  // OpenCode config for the /fable-plan planning skill (see FABLE_PLAN.md).
  // Agents are defined in .opencode/agents/*.md; this file owns provider/model config.
  // The Sol scout and the refusal fallback do NOT go through OpenCode — they run via
  // `codex exec` on the OpenAI subscription, so no OpenAI provider entry is needed here.
  // Docs: https://opencode.ai/docs/config  https://opencode.ai/docs/providers
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "models": {
        // ---- DeepSeek V4 Flash — the context-prep assembler (mechanical embed of the
        // scout's manifest into context.md). Flash's real reasoning levels are high/xhigh
        // only (low/medium map to high); its work is mechanical, so cost is controlled via
        // the output cap, not effort. NEVER send DeepSeek's native "max" effort value —
        // OpenRouter rejects it with a 400; only low/medium/high are valid here.
        "deepseek/deepseek-v4-flash": {
          "limit": { "context": 1048576, "output": 8192 },
          "options": { "reasoning": { "effort": "high" } }
        },
        // ---- Claude Fable 5 — the planner and the optional planner-manifest pre-pass.
        // PREMIUM ($10/$50 per 1M): at most 1x plan + 1x user-requested revision
        // (+1x manifest pre-pass under --manifest) per run. Always high effort — never
        // higher (xhigh multiplies thinking-token spend several-fold for marginal
        // gains), never lower. OpenCode applies OpenRouter cache breakpoints for
        // Claude models automatically (cache reads bill at ~0.1x), which is what makes
        // the planner's bounded read turns affordable.
        //
        // Output cap: OpenCode HARDCODES a global clamp of 32,000 output tokens per
        // response (OUTPUT_TOKEN_MAX in provider/transform.ts: the effective cap is
        // min(limit.output, 32000)) — this config can LOWER it but never raise it.
        // A response includes the turn's thinking (~8K at high effort), and a
        // response that hits the cap mid-tool-call is aborted invisibly
        // (finish=length, "Tool execution aborted") — this killed two S5b plan runs
        // on 2026-07-13. Mitigated in planner.md by writing the plan in chunks, each
        // response well under the clamp. To genuinely raise the clamp, launch
        // OpenCode with OPENCODE_EXPERIMENTAL_OUTPUT_TOKEN_MAX=65536 (env var only;
        // this limit.output then becomes the effective ceiling).
        "anthropic/claude-fable-5": {
          "limit": { "context": 1000000, "output": 65536 },
          "options": { "reasoning": { "effort": "high" } }
        }
      }
    }
  }
}
